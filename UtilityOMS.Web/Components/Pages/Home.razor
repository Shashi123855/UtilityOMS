@page "/"
@rendermode InteractiveServer
@using UtilityOMS.Web.Services

@inject OutageClientService OutageService
@inject CrewClientService CrewService

<div class="mb-4">
    <h4 style="font-weight:700; color:#1a1f3c;">
        👋 Welcome back, Admin
    </h4>
    <p style="color:#888; font-size:0.9rem; margin:0;">
        Here's what's happening with your utility network today.
    </p>
</div>

@if (_loading)
{
    <div class="loading-container">
        <div class="spinner-custom"></div>
        <span>Loading dashboard...</span>
    </div>
}
else
{
    <!-- KPI Cards -->
    <div class="row g-3 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="kpi-card">
                <div class="kpi-icon red">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                </div>
                <div>
                    <div class="kpi-value">@_totalOutages</div>
                    <div class="kpi-label">Total Outages</div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="kpi-card">
                <div class="kpi-icon orange">
                    <i class="bi bi-lightning-charge-fill"></i>
                </div>
                <div>
                    <div class="kpi-value">@_activeOutages</div>
                    <div class="kpi-label">Active Outages</div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="kpi-card">
                <div class="kpi-icon green">
                    <i class="bi bi-check-circle-fill"></i>
                </div>
                <div>
                    <div class="kpi-value">@_resolvedOutages</div>
                    <div class="kpi-label">Resolved Today</div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="kpi-card">
                <div class="kpi-icon blue">
                    <i class="bi bi-people-fill"></i>
                </div>
                <div>
                    <div class="kpi-value">@_availableCrews</div>
                    <div class="kpi-label">Crews Available</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Outages + Crew Status -->
    <div class="row g-3">
        <!-- Recent Outages -->
        <div class="col-xl-8">
            <div class="panel">
                <div class="panel-title">
                    <i class="bi bi-clock-history" style="color:#4e9af1;"></i>
                    Recent Outages
                </div>
                @if (!_recentOutages.Any())
                {
                    <div class="empty-state">
                        <i class="bi bi-inbox"></i>
                        <p>No outages reported yet.<br />The grid is running smoothly! ✅</p>
                    </div>
                }
                else
                {
                    <table class="custom-table">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Area</th>
                                <th>Status</th>
                                <th>Reported</th>
                                <th>Crew</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var o in _recentOutages)
                            {
                                <tr>
                                    <td>
                                        <strong style="color:#1a1f3c;">@o.Title</strong>
                                        <div style="font-size:0.75rem; color:#aaa;">@o.Cause</div>
                                    </td>
                                    <td style="color:#666;">@o.AffectedArea</td>
                                    <td>
                                        <span class="@GetStatusBadge(o.Status)">@o.Status</span>
                                    </td>
                                    <td style="color:#888; font-size:0.8rem;">
                                        @o.ReportedAt.ToString("MMM dd, hh:mm tt")
                                    </td>
                                    <td style="color:#666; font-size:0.82rem;">
                                        @(o.AssignedCrewName ?? "— Unassigned")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        <!-- Crew Status -->
        <div class="col-xl-4">
            <div class="panel">
                <div class="panel-title">
                    <i class="bi bi-people" style="color:#4e9af1;"></i>
                    Crew Status
                </div>
                @if (!_crews.Any())
                {
                    <div class="empty-state">
                        <i class="bi bi-people"></i>
                        <p>No crews added yet.</p>
                    </div>
                }
                else
                {
                    @foreach (var crew in _crews)
                    {
                        <div style="display:flex; align-items:center; justify-content:space-between;
                            padding:12px 0; border-bottom:1px solid #f0f2f5;">
                            <div style="display:flex; align-items:center; gap:12px;">
                                <div style="width:40px; height:40px; border-radius:10px;
                                    background:#f0f7ff; display:flex; align-items:center;
                                    justify-content:center; color:#4e9af1; font-weight:700;">
                                    @crew.Name[0]
                                </div>
                                <div>
                                    <div style="font-weight:600; font-size:0.875rem; color:#1a1f3c;">
                                        @crew.Name
                                    </div>
                                    <div style="font-size:0.75rem; color:#aaa;">
                                        @crew.LeadTechnician
                                    </div>
                                </div>
                            </div>
                            <span class="@GetCrewBadge(crew.Status)">@crew.Status</span>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private List<OutageDto> _recentOutages = new();
    private List<CrewDto> _crews = new();

    private int _totalOutages = 0;
    private int _activeOutages = 0;
    private int _resolvedOutages = 0;
    private int _availableCrews = 0;

    protected override async Task OnInitializedAsync()
    {
        var outages = await OutageService.GetAllAsync();
        _crews = await CrewService.GetAllAsync();

        _totalOutages = outages.Count;
        _activeOutages = outages.Count(o => o.Status is "Reported" or "InProgress");
        _resolvedOutages = outages.Count(o => o.Status == "Resolved");
        _availableCrews = _crews.Count(c => c.Status == "Available");
        _recentOutages = outages.OrderByDescending(o => o.ReportedAt).Take(6).ToList();

        _loading = false;
    }

    private string GetStatusBadge(string status) => status switch
    {
        "Reported" => "badge-reported",
        "InProgress" => "badge-inprogress",
        "Resolved" => "badge-resolved",
        _ => "badge-reported"
    };

    private string GetCrewBadge(string status) => status switch
    {
        "Available" => "badge-available",
        "Dispatched" => "badge-dispatched",
        "OnSite" => "badge-onsite",
        "OffDuty" => "badge-offduty",
        _ => "badge-offduty"
    };
}